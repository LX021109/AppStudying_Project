def load_questions_from_json(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        return json.load(f)

class AchievementManager:
    def __init__(self):
        self.achievements = ACHIEVEMENTS
        self.progress = {}
        self.load_achievements()

    def load_achievements(self):
        try:
            if os.path.exists(ACHIEVEMENTS_FILE):
                with open(ACHIEVEMENTS_FILE, 'r', encoding='utf-8') as f:
                    saved_data = json.load(f)
                    for saved_achievement in saved_data.get('achievements', []):
                        for achievement in self.achievements:
                            if achievement['id'] == saved_achievement['id']:
                                achievement.update(saved_achievement)
                    self.progress = saved_data.get('progress', {})
        except Exception as e:
            print(f"Error loading achievements: {e}")
            self.progress = {}

    def save_achievements(self):
        try:
            with open(ACHIEVEMENTS_FILE, 'w', encoding='utf-8') as f:
                json.dump({
                    'achievements': self.achievements,
                    'progress': self.progress
                }, f, ensure_ascii=False, indent=2)
        except Exception as e:
            print(f"Error saving achievements: {e}")

    def increment_progress(self, topic=None, level=None):
        newly_unlocked = []

        for achievement in self.achievements:
            if achievement['completed']:
                continue

            condition = achievement['condition']

            if 'mixed_levels' in condition:
                mixed_progress = self.progress.get(achievement['id'], {})
                level_counts = condition['mixed_levels']

                all_met = True
                for level_req, count_req in level_counts.items():
                    current_count = mixed_progress.get(level_req, 0)
                    if level_req == level:
                        current_count += 1
                        current_count = min(current_count, count_req)
                        mixed_progress[level_req] = current_count

                    if current_count < count_req:
                        all_met = False

                self.progress[achievement['id']] = mixed_progress
                if all_met:
                    achievement['completed'] = True
                    achievement['date_earned'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    newly_unlocked.append(achievement)

            else:
                matches_condition = True

                if 'topic' in condition and topic:
                    algebra_keywords = ['уравнени', 'алгебр', 'неравенств', 'модул', 'параметр', 'выражени',
                                        'функции', 'график']
                    if not any(keyword in topic.lower() for keyword in algebra_keywords):
                        matches_condition = False
                elif 'topic' in condition:
                    if condition['topic'] == 'алгебра':
                        algebra_keywords = ['уравнени', 'алгебр', 'неравенств', 'модул', 'параметр', 'выражени',
                                            'функции', 'график']
                        if not any(keyword in topic.lower() for keyword in algebra_keywords):
                            matches_condition = False
                    elif condition['topic'] == 'геометрия':
                        if 'геометр' not in topic.lower():
                            matches_condition = False
                    elif condition['topic'] not in topic.lower():
                        matches_condition = False

                if 'level' in condition:
                    russian_level_map = {"easy": "лёгкий", "medium": "средний", "hard": "тяжёлый"}
                    normalized_level = level
                    if level in ['easy', 'medium', 'hard']:
                        normalized_level = russian_level_map[level]

                    if normalized_level != condition['level']:
                        matches_condition = False

                if matches_condition:
                    current_progress = self.progress.get(achievement['id'], 0)
                    current_progress += 1
                    current_progress = min(current_progress, condition['count'])
                    self.progress[achievement['id']] = current_progress

                    if current_progress >= condition['count']:
                        achievement['completed'] = True
                        achievement['date_earned'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                        newly_unlocked.append(achievement)

        self.save_achievements()
        return newly_unlocked

    def reset_achievements(self):
        for achievement in self.achievements:
            achievement['completed'] = False
            achievement['date_earned'] = None
        self.progress = {}
        self.save_achievements()

