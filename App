class ResultWindow(QWidget):
    def __init__(self, stacked_widget, level_idx, score, total_questions, questions_data, time_spent, user_answers):
        super().__init__()
        self.stacked_widget = stacked_widget
        self.level_idx = level_idx
        self.score = score
        self.total_questions = total_questions
        self.questions_data = questions_data
        self.time_spent = time_spent
        self.user_answers = user_answers
        self.setWindowTitle('Результаты')
        self.setFixedSize(*WINDOW_SIZE)
        self.initUI()

    def initUI(self):
        self.label = QLabel(self)
        pixmap = QPixmap(FON_IMAGE)
        self.label.setPixmap(pixmap)
        self.label.setAlignment(Qt.AlignCenter)
        self.label.setScaledContents(True)
        self.label.resize(self.width(), self.height())

        title = QLabel(f'Результаты уровня {self.level_idx}', self)
        title.setStyleSheet(
            "background: white; color: black; border-radius: 25px; font-size: 18px; border: 2px solid #ddd;")
        title.setFixedSize(400, 60)
        title.move(self.width() // 2 - 200, 20)
        title.setAlignment(Qt.AlignCenter)

        minutes = self.time_spent // 60
        seconds = self.time_spent % 60
        if minutes > 0:
            time_text = f"{minutes} мин {seconds} сек"
        else:
            time_text = f"{seconds} сек"

        results_text = f"Правильных: {self.score}/{self.total_questions}\nПотрачено: {time_text}"
        results_label = QLabel(results_text, self)
        results_label.setStyleSheet(
            "background: white; color: black; border-radius: 15px; font-size: 16px; border: 2px solid #ddd;")
        results_label.setFixedSize(300, 100)
        results_label.move(450, 100)
        results_label.setAlignment(Qt.AlignCenter)

        scroll_area = QScrollArea(self)
        scroll_area.setGeometry(50, 220, 1100, 350)
        scroll_area.setStyleSheet("QScrollArea { border: none; background: transparent; }")

        scroll_content = QWidget()
        scroll_layout = QVBoxLayout(scroll_content)
        scroll_layout.setAlignment(Qt.AlignTop)

        for i, q in enumerate(self.questions_data):
            q_label = QLabel(f"Вопрос {i + 1}: {q['question']}", scroll_content)
            q_label.setWordWrap(True)
            q_label.setFixedWidth(1060)
            q_label.setStyleSheet(
                "background: white; color: black; border-radius: 10px; font-size: 16px; border: 1px solid #ddd; padding: 10px;")
            scroll_layout.addWidget(q_label)

            if i < len(self.user_answers):
                user_answer_idx = self.user_answers[i]
                user_answer_text = q["options"][user_answer_idx]
            else:
                user_answer_text = "Не отвечено"
            user_label = QLabel(f"Ваш ответ: {user_answer_text}", scroll_content)
            user_label.setFixedWidth(1060)
            correct_answer = q.get("correct", q.get("correct_answer"))
            if user_answer_text == correct_answer:
                user_label.setStyleSheet(
                    "background: #e6f9e6; color: black; border-radius: 5px; font-size: 12px; border: 1px solid #ccc; padding: 8px;")
            else:
                user_label.setStyleSheet(
                    "background: #ffe6e6; color: black; border-radius: 5px; font-size: 12px; border: 1px solid #ccc; padding: 8px;")
            scroll_layout.addWidget(user_label)

            correct_answer = q.get("correct", q.get("correct_answer"))
            correct_label = QLabel(f"Правильный ответ: {correct_answer}", scroll_content)
            correct_label.setFixedWidth(1060)
            correct_label.setStyleSheet(
                "background: #e6f9e6; color: black; border-radius: 5px; font-size: 12px; border: 1px solid #ccc; padding: 8px;")
            scroll_layout.addWidget(correct_label)

            exp_label = QLabel(f"Пояснение: {q['explanation']}", scroll_content)
            exp_label.setWordWrap(True)
            exp_label.setFixedWidth(1060)
            exp_label.setStyleSheet(
                "background: #f0f8ff; color: black; border-radius: 10px; font-size: 12px; border: 1px solid #ccc; padding: 10px;")
            scroll_layout.addWidget(exp_label)

            spacer = QLabel("", scroll_content)
            spacer.setFixedHeight(10)
            scroll_layout.addWidget(spacer)

        scroll_area.setWidget(scroll_content)
        scroll_area.setWidgetResizable(True)

        back_button = QPushButton('Вернуться в главное меню', self)
        back_button.setFixedSize(250, 70)
        back_button.setStyleSheet(RECT_BTN_STYLE)
        back_button.move(self.width() - 260, 10)
        back_button.clicked.connect(self.backToMain)

    def backToMain(self):
        for i in range(self.stacked_widget.count()):
            widget = self.stacked_widget.widget(i)
            if isinstance(widget, AchievementsWindow):
                widget.deleteLater()

        self.stacked_widget.setCurrentIndex(0)

class TasksLevelWindow(QWidget):
    def __init__(self, title, stacked_widget, level_idx, total_questions=5):
        super().__init__()
        self.stacked_widget = stacked_widget
        self.level_idx = level_idx
        self.total_questions = total_questions
        self.setWindowTitle(title)
        self.setFixedSize(*WINDOW_SIZE)

        time_total = {1: 300, 2: 600, 3: 900}.get(level_idx, 300)
        self.time_left = time_total

        self.timer = QTimer(self)
        self.timer.timeout.connect(self.update_timer)
        self.time_up_shown = False
        self.current_question_index = 0
        self.score = 0
        self.questions_data = []
        self.user_answers = []

        self.initUI(title)
        self.generate_questions()
        self.start_timer()

    def __del__(self):
        if self.timer and self.timer.isActive():
            self.timer.stop()

    def hideEvent(self, event):
        if self.timer and self.timer.isActive():
            self.timer.stop()
        super().hideEvent(event)

    def showEvent(self, event):
        super().showEvent(event)
        if self.timer and not self.timer.isActive() and self.time_left > 0:
            self.timer.start(1000)

    def initUI(self, title):
        self.label = QLabel(self)
        pixmap = QPixmap(FON_IMAGE)
        self.label.setPixmap(pixmap)
        self.label.setAlignment(Qt.AlignCenter)
        self.label.setScaledContents(True)
        self.label.resize(self.width(), self.height())

        self.level_title = QLabel(title, self)
        self.level_title.setStyleSheet(
            "background: white; color: black; border-radius: 25px; font-size: 18px; border: 2px solid #ddd;")
        self.level_title.setAlignment(Qt.AlignCenter)
        self.level_title.setGeometry(450, 20, 300, 50)

        self.timer_label = QLabel(self.format_time(self.time_left), self)
        self.timer_label.setStyleSheet("font-size: 24px; color: white; background: rgba(0,0,0,0.5); padding: 10px;")
        self.timer_label.setGeometry(20, 10, 150, 50)

    def generate_questions(self):
        all_questions = load_questions_from_json('questions.json')
        level_map = {1: "лёгкий", 2: "средний", 3: "тяжёлый"}
        target_level = level_map.get(self.level_idx, "лёгкий")

        if target_level == "лёгкий":
            filtered_questions = [q for q in all_questions if q["level"] in ["лёгкий", "easy"]]
        elif target_level == "средний":
            filtered_questions = [q for q in all_questions if q["level"] in ["средний", "medium"]]
        elif target_level == "тяжёлый":
            filtered_questions = [q for q in all_questions if q["level"] in ["тяжёлый", "hard"]]
        else:
            filtered_questions = [q for q in all_questions if q["level"] == target_level]

        selected_questions = random.sample(filtered_questions, min(self.total_questions, len(filtered_questions)))
        self.questions_data = selected_questions
        self.show_current_question()

    def restart_level(self):
        self.timer.stop()
        self.time_up_shown = False
        self.current_question_index = 0
        self.score = 0
        self.user_answers = []
        if hasattr(self, '_current_question_widgets'):
            for widget in self._current_question_widgets:
                widget.deleteLater()
        self._current_question_widgets = []
        self.generate_questions()
        time_total = {1: 300, 2: 600, 3: 900}.get(self.level_idx, 300)
        self.time_left = time_total
        self.timer_label.setText(self.format_time(self.time_left))
        self.start_timer()

    def show_current_question(self):
        if self.current_question_index < len(self.questions_data):
            current_q = self.questions_data[self.current_question_index]
            self.display_question_ui(current_q)
        else:
            self.go_to_results()

    def display_question_ui(self, data):
        if hasattr(self, '_current_question_widgets'):
            for widget in self._current_question_widgets:
                widget.hide()
                widget.deleteLater()
        self._current_question_widgets = []

        question_label = QLabel(data["question"], self)
        question_label.setWordWrap(True)
        question_label.setAlignment(Qt.AlignCenter)
        question_label.setFixedSize(800, 100)
        question_label.move(200, 150)
        question_label.setStyleSheet(
            "background: white; "
            "color: black; "
            "border-radius: 35px; "
            "font-size: 18px; "
            "border: 2px solid #ddd; "
            "padding: 10px;"
        )
        question_label.show()
        self._current_question_widgets.append(question_label)

        options = data["options"]
        for i, opt in enumerate(options):
            btn = QPushButton(opt, self)
            btn.setFixedSize(250, 60)
            btn.setStyleSheet(OVAL_BTN_STYLE)
            x = 325 + (i % 2) * 270
            y = 300 + (i // 2) * 120
            btn.move(x, y)
            correct_answer = data.get("correct", data.get("correct_answer"))
            btn.setProperty("correct_answer", correct_answer)
            btn.clicked.connect(lambda _, idx=i: self.check_answer(idx))
            btn.show()
            self._current_question_widgets.append(btn)

    def check_answer(self, option_index):
        current_q = self.questions_data[self.current_question_index]
        correct_answer = current_q.get("correct", current_q.get("correct_answer"))
        if current_q["options"][option_index] == correct_answer:
            self.score += 1
            topic = current_q.get("topic", "")
            level = current_q["level"]
            achievement_manager.increment_progress(topic=topic, level=level)
        self.user_answers.append(option_index)
        self.current_question_index += 1
        self.show_current_question()

    def go_to_results(self):
        self.timer.stop()
        time_spent = {1: 300, 2: 600, 3: 900}.get(self.level_idx, 300) - self.time_left
        time_spent = max(0, time_spent)
        result_window = ResultWindow(
            self.stacked_widget,
            self.level_idx,
            self.score,
            self.total_questions,
            self.questions_data,
            time_spent,
            self.user_answers
        )
        self.stacked_widget.addWidget(result_window)
        self.stacked_widget.setCurrentWidget(result_window)

    def go_to_results_modal(self, container):
        self.timer.stop()
        container.close()
        time_spent = {1: 300, 2: 600, 3: 900}.get(self.level_idx, 300) - self.time_left
        time_spent = max(0, time_spent)
        result_window = ResultWindow(
            self.stacked_widget,
            self.level_idx,
            self.score,
            self.total_questions,
            self.questions_data,
            time_spent,
            self.user_answers
        )
        self.stacked_widget.addWidget(result_window)
        self.stacked_widget.setCurrentWidget(result_window)

    def format_time(self, seconds):
        minutes = seconds // 60
        secs = seconds % 60
        return f"{minutes:02d}:{secs:02d}"

    def start_timer(self):
        self.timer.start(1000)

    def update_timer(self):
        self.time_left -= 1
        if self.time_left >= 0:
            self.timer_label.setText(self.format_time(self.time_left))
        if self.time_left <= 0:
            self.time_left = 0
            self.timer.stop()
            if not self.time_up_shown:
                self.show_time_up_message()

    def show_time_up_message(self):
        self.time_up_shown = True

        self.modal_container = QWidget(self)
        self.modal_container.setGeometry(0, 0, self.width(), self.height())
        self.modal_container.setStyleSheet("background: transparent;")
        self.modal_container.setAttribute(Qt.WA_TransparentForMouseEvents, False)

        overlay = QWidget(self.modal_container)
        overlay.setGeometry(0, 0, self.width(), self.height())
        overlay.setStyleSheet("background: rgba(0,0,0,0.5);")

        message_box = QWidget(self.modal_container)
        message_box.setStyleSheet("background: white; border-radius: 25px; border: 2px solid #ddd;")
        message_box.setGeometry(400, 200, 400, 200)

        layout = QVBoxLayout(message_box)
        label = QLabel("Время истекло!", message_box)
        label.setStyleSheet("font-size: 24px; color: black; background: transparent; border: none;")
        label.setAlignment(Qt.AlignCenter)
        button = QPushButton("Перейти к ответам", message_box)
        button.setStyleSheet(RECT_BTN_STYLE)
        button.setFixedSize(250, 70)
        button.clicked.connect(lambda: self.go_to_results_modal(self.modal_container))
        layout.addWidget(label)
        layout.addWidget(button)
        layout.setAlignment(Qt.AlignCenter)

        self.modal_container.show()
        message_box.raise_()

    def backToLevel(self):
        self.timer.stop()
        self.stacked_widget.setCurrentIndex(self.level_idx)

