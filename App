        self.buttons = []
        for text, idx, y in levels:
            btn = QPushButton(text, self)
            btn.setFixedSize(300, 70)
            btn.setStyleSheet(RECT_BTN_STYLE)
            btn.move(445, y)
            btn.clicked.connect(lambda _, i=idx: self.openLevel(i))
            self.buttons.append(btn)

    def reset_achievements(self):
        achievement_manager.reset_achievements()

    def open_achievements(self):
        for i in range(self.stacked_widget.count()):
            widget = self.stacked_widget.widget(i)
            if isinstance(widget, AchievementsWindow):
                self.stacked_widget.setCurrentWidget(widget)
                return

        achievements_window = AchievementsWindow(self.stacked_widget)
        self.stacked_widget.addWidget(achievements_window)
        self.stacked_widget.setCurrentWidget(achievements_window)

    def openLevel(self, level_idx):
        tasks_window = None
        for i in range(self.stacked_widget.count()):
            widget = self.stacked_widget.widget(i)
            if isinstance(widget, TasksLevelWindow) and widget.level_idx == level_idx:
                tasks_window = widget
                break

        if tasks_window is None:
            level_titles = ["", "Уровень 1 (Лёгкий)", "Уровень 2 (Средний)", "Уровень 3 (Сложный)"]
            title = level_titles[level_idx] if level_idx < len(level_titles) else f"Уровень {level_idx}"
            tasks_window = TasksLevelWindow(title, self.stacked_widget, level_idx, 5)
            self.stacked_widget.addWidget(tasks_window)

        tasks_window.restart_level()
        self.stacked_widget.setCurrentWidget(tasks_window)

class AchievementsWindow(QWidget):
    def __init__(self, stacked_widget):
        super().__init__()
        self.stacked_widget = stacked_widget
        self.setWindowTitle('Достижения')
        self.setFixedSize(*WINDOW_SIZE)
        self.initUI()

    def initUI(self):
        self.label = QLabel(self)
        pixmap = QPixmap(FON_IMAGE)
        self.label.setPixmap(pixmap)
        self.label.setAlignment(Qt.AlignCenter)
        self.label.setScaledContents(True)
        self.label.resize(self.width(), self.height())

        title = QLabel('Достижения', self)
        title.setStyleSheet(
            "background: white; color: black; border-radius: 25px; font-size: 24px; border: 2px solid #ddd;")
        title.setFixedSize(300, 60)
        title.move(self.width() // 2 - 150, 20)
        title.setAlignment(Qt.AlignCenter)

        exit_button = QPushButton('Выйти', self)
        exit_button.setFixedSize(100, 50)
        exit_button.setStyleSheet(RECT_BTN_STYLE)
        exit_button.move(20, 20)
        exit_button.clicked.connect(self.backToMain)

        scroll_area = QScrollArea(self)
        scroll_area.setGeometry(50, 100, 1100, 500)
        scroll_area.setStyleSheet("QScrollArea { border: none; background: transparent; }")

        scroll_content = QWidget()
        scroll_layout = QVBoxLayout(scroll_content)
        scroll_layout.setAlignment(Qt.AlignTop)

        for achievement in achievement_manager.achievements:
            achievement_widget = self.create_achievement_widget(achievement)
            scroll_layout.addWidget(achievement_widget)

        scroll_area.setWidget(scroll_content)
        scroll_area.setWidgetResizable(True)

    def create_achievement_widget(self, achievement):
        container = QWidget()
        container.setStyleSheet("""
            QWidget {
                background: white;
                border-radius: 15px;
                border: 2px solid #ddd;
                padding: 10px;
                margin: 10px;
            }
        """)
        container_layout = QVBoxLayout(container)

        header_layout = QVBoxLayout()

        if achievement['completed']:
            name_label = QLabel(f"🏆 {achievement['name']} ✅", container)
        else:
            name_label = QLabel(f"🏆 {achievement['name']}", container)
        name_label.setStyleSheet("font-size: 18px; font-weight: bold; color: black; margin-bottom: 5px;")
        name_label.setAlignment(Qt.AlignCenter)
        header_layout.addWidget(name_label)

        desc_label = QLabel(achievement['description'], container)
        desc_label.setStyleSheet("font-size: 16px; color: black; margin: 5px;")
        desc_label.setAlignment(Qt.AlignCenter)
        desc_label.setWordWrap(True)
        header_layout.addWidget(desc_label)

        if 'mixed_levels' in achievement['condition']:
            progress_text = self.get_mixed_progress_text(achievement)
            progress_label = QLabel(progress_text, container)
            progress_label.setStyleSheet("font-size: 16px; color: black; margin: 5px;")
            progress_label.setAlignment(Qt.AlignCenter)
            header_layout.addWidget(progress_label)

            mixed_progress = achievement_manager.progress.get(achievement['id'], {})
            for level, required in achievement['condition']['mixed_levels'].items():
                current = min(mixed_progress.get(level, 0), required)
                level_progress = QLabel(f"{level.capitalize()}: {current}/{required}", container)
                level_progress.setStyleSheet("font-size: 12px; color: black; margin: 2px;")
                level_progress.setAlignment(Qt.AlignCenter)
                header_layout.addWidget(level_progress)
        else:
            required = achievement['condition']['count']
            current = achievement_manager.progress.get(achievement['id'], 0)
            current = min(current, required)

            if achievement['completed']:
                progress_label = QLabel(f"Завершено!", container)
            else:
                progress_label = QLabel(f"Прогресс: {current}/{required}", container)
            progress_label.setStyleSheet("font-size: 16px; color: black; margin: 5px;")
            progress_label.setAlignment(Qt.AlignCenter)
            header_layout.addWidget(progress_label)

        progress_percent = self.calculate_achievement_progress(achievement)
        progress_status = QLabel(f"{int(progress_percent)}%", container)
        progress_status.setStyleSheet("font-size: 16px; color: black; margin: 5px;")
        progress_status.setAlignment(Qt.AlignCenter)
        header_layout.addWidget(progress_status)

        container_layout.addLayout(header_layout)

        if achievement['completed']:
            award_claimed = achievement.get('date_earned', None) is not None
            if award_claimed:
                award_button = QPushButton('Награда получена', container)
                award_button.setFixedSize(200, 50)
                award_button.setStyleSheet(
                    "QPushButton{background: #cccccc; color: #666666; border-radius: 25px; font-size: 16px; border: 2px solid #aaa;}")
                award_button.clicked.connect(lambda: self.show_award_popup(achievement))
            else:
                award_button = QPushButton('Забрать награду', container)
                award_button.setFixedSize(200, 50)
                award_button.setStyleSheet(RECT_BTN_STYLE)
                award_button.clicked.connect(lambda: self.claim_achievement(achievement))

            h_layout = QHBoxLayout()
            h_layout.addStretch()
            h_layout.addWidget(award_button)
            h_layout.addStretch()
            container_layout.addLayout(h_layout)

        container_layout.addStretch()

        return container

    def show_award_popup(self, achievement):
        modal_container = QWidget(self)
        modal_container.setGeometry(0, 0, self.width(), self.height())
        modal_container.setStyleSheet("background: transparent;")
        modal_container.setAttribute(Qt.WA_TransparentForMouseEvents, False)

        overlay = QWidget(modal_container)
        overlay.setGeometry(0, 0, self.width(), self.height())
        overlay.setStyleSheet("background: rgba(0,0,0,0.5);")

        message_box = QWidget(modal_container)
        message_box.setStyleSheet("background: white; border-radius: 25px; border: 2px solid #ddd;")
        message_box.setGeometry(400, 200, 400, 200)

        layout = QVBoxLayout(message_box)

        label = QLabel(f"Достижение {achievement['name']} выполнено!", message_box)
        label.setStyleSheet("font-size: 18px; color: black; background: transparent; border: none;")
        label.setAlignment(Qt.AlignCenter)
        label.setWordWrap(True)

        close_button = QPushButton("×", message_box)
        close_button.setFixedSize(30, 30)
        close_button.setStyleSheet("""
            QPushButton {
                font-size: 20px;
                font-weight: bold;
                background-color: #ff6b6b;
                color: white;
                border-radius: 15px;
                border: none;
            }
            QPushButton:hover {
                background-color: #ff5252;
            }
        """)
        close_button.move(message_box.width() - 35, 5)
        close_button.clicked.connect(lambda: modal_container.deleteLater())

        layout.addWidget(label)
        layout.setAlignment(Qt.AlignCenter)

        modal_container.show()
        message_box.raise_()

    def get_mixed_progress_text(self, achievement):
        mixed_progress = achievement_manager.progress.get(achievement['id'], {})
        total_completed = 0
        total_required = 0

        for level, required in achievement['condition']['mixed_levels'].items():
            current = min(mixed_progress.get(level, 0), required)
            total_completed += current
            total_required += required

        return f"Прогресс: {total_completed}/{total_required}"

    def calculate_achievement_progress(self, achievement):
        if 'mixed_levels' in achievement['condition']:
            mixed_progress = achievement_manager.progress.get(achievement['id'], {})
            total_completed = 0
            total_required = 0

            for level, required in achievement['condition']['mixed_levels'].items():
                current = min(mixed_progress.get(level, 0), required)
                total_completed += current
                total_required += required

            if total_required == 0:
                return 0
            return min(100, (total_completed / total_required) * 100)
        else:
            required = achievement['condition']['count']
            current = min(achievement_manager.progress.get(achievement['id'], 0), required)
            if required == 0:
                return 0
            return min(100, (current / required) * 100)

    def claim_achievement(self, achievement):
        achievement['date_earned'] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        achievement_manager.save_achievements()

        from PyQt5.QtWidgets import QMessageBox
        msg = QMessageBox()
        msg.setWindowTitle('Поздравляем!')
        msg.setText(f'Вы выполнили достижение "{achievement["name"]}"!')
        msg.setStyleSheet("background-color: white; color: black;")
        msg.exec_()

        self.refresh_achievements()

    def refresh_achievements(self):
        for i in reversed(range(self.layout().count())):
            self.layout().itemAt(i).widget().setParent(None)

        self.initUI()

    def backToMain(self):
        self.stacked_widget.setCurrentIndex(0)

def createApp():
    app = QApplication(sys.argv)
    icon_path = os.path.join(base_path, "Materials", "redApple.ico")
    app.setWindowIcon(QIcon(icon_path))
    stack = QStackedWidget()
    stack.setFixedSize(*WINDOW_SIZE)
    main_win = MainWindow(stack)
    stack.addWidget(main_win)
    stack.show()
    sys.exit(app.exec_())

if __name__ == '__main__':
    createApp()
